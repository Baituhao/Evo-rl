            "observation.images.left": {
                "type": "VISUAL",
                "shape": [
                    3,
                    480,
                    640
                ]
            },
            "observation.images.right": {
                "type": "VISUAL",
                "shape": [
                    3,
                    480,
                    640
                ]
            },
            "observation.state": {
                "type": "STATE",
                "shape": [
                    16
                ]
            }
        },
        "license": null,
        "max_action_dim": 32,
        "max_period": 4.0,
        "max_state_dim": 32,
        "min_period": 0.004,
        "n_action_steps": 50,
        "n_obs_steps": 1,
        "normalization_mapping": {
            "ACTION": "QUANTILES",
            "STATE": "QUANTILES",
            "VISUAL": "IDENTITY"
